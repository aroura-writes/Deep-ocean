# ── Contentful CMS ─────────────────────────────────────────────────────────
# These are injected AUTOMATICALLY when you use the Vercel + Contentful
# integration from the Vercel Marketplace. You only need them manually locally.

# Found in: Contentful → Settings → API Keys
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_DELIVERY_TOKEN=your_content_delivery_api_token_here

# Optional: only needed if you want draft/preview content
CONTENTFUL_PREVIEW_TOKEN=your_content_preview_api_token_here

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
